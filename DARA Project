al_media'].replace({\n","    'Less than 1 hour': 1,\n","    '1–2 hours': 2,\n","    '2–4 hours': 3,\n","    '4–6 hours': 5,\n","    'More than 6 hours': 7\n","})\n","\n","df['sleep'] = df['sleep'].replace({\n","    'Less than 4 hours': 3,\n","    '4–6 hours': 5,\n","    '6–8 hours': 7,\n","    'More than 8 hours': 9\n","})\n","\n","df['phone_check'] = df['phone_check'].replace({\n","    'Less than 10 times': 5,\n","    '10–20 times': 15,\n","    '20–50 times': 35,\n","    'More than 50 times': 60\n","})\n","\n","# Convert safely\n","df['screen_time'] = pd.to_numeric(df['screen_time'], errors='coerce')\n","df['social_media'] = pd.to_numeric(df['social_media'], errors='coerce')\n","df['sleep'] = pd.to_numeric(df['sleep'], errors='coerce')\n","df['phone_check'] = pd.to_numeric(df['phone_check'], errors='coerce')\n","\n","# Yes/No → 1/0\n","df['night_usage'] = df['night_usage'].map({'Yes':1, 'No':0})\n","\n","# Fix numeric columns\n","df['restlessness'] = pd.to_numeric(df['restlessness'], errors='coerce')\n","df['sleep_issue'] = pd.to_numeric(df['sleep_issue'], errors='coerce')\n","df['concentration'] = pd.to_numeric(df['concentration'], errors='coerce')\n","\n","# Fill missing\n","df = df.fillna(0)\n","\n","# -------------------------------\n","# NORMALIZATION\n","# -------------------------------\n","def normalize(col):\n","    return (col - col.min()) / (col.max() - col.min() + 1e-5)\n","\n","df['screen_norm'] = normalize(df['screen_time'])\n","df['social_norm'] = normalize(df['social_media'])\n","df['sleep_norm'] = normalize(df['sleep'])\n","df['phone_norm'] = normalize(df['phone_check'])\n","df['rest_norm'] = normalize(df['restlessness'])\n","df['sleep_issue_norm'] = normalize(df['sleep_issue'])\n","df['conc_norm'] = normalize(df['concentration'])\n","\n","# -------------------------------\n","# HEALTH RISK CALCULATIONS (FINAL FIXED)\n","# -------------------------------\n","\n","# Eye Risk (VARIATION FIXED)\n","df['eye_risk_%'] = (\n","    (df['screen_time'] / (df['screen_time'].max() + 1e-5)) * 60 +\n","    (df['phone_check'] / (df['phone_check'].max() + 1e-5)) * 20 +\n","    (1 - df['sleep'] / (df['sleep'].max() + 1e-5)) * 20\n",")\n","\n","# Depression Risk\n","df['depression_risk_%'] = (\n","    0.3 * df['social_norm'] +\n","    0.3 * df['rest_norm'] +\n","    0.2 * df['sleep_issue_norm'] +\n","    0.2 * (1 - df['sleep_norm'])\n",") * 100\n","\n","# Sleep Risk (VARIATION FIXED)\n","df['sleep_risk_%'] = (\n","    (1 - df['sleep'] / (df['sleep'].max() + 1e-5)) * 50 +\n","    (df['screen_time'] / (df['screen_time'].max() + 1e-5)) * 30 +\n","    df['night_usage'] * 20\n",")\n","\n","# Anxiety Risk\n","df['anxiety_risk_%'] = (\n","    0.3 * df['phone_norm'] +\n","    0.3 * df['rest_norm'] +\n","    0.2 * df['social_norm'] +\n","    0.2 * df['conc_norm']\n",") * 100\n","\n","# Final safety (VERY IMPORTANT)\n","df.replace([np.inf, -np.inf], 0, inplace=True)\n","df = df.fillna(0)\n","\n","# -------------------------------\n","# OUTPUT SAMPLE\n","# -------------------------------\n","print(df[['eye_risk_%','depression_risk_%','sleep_risk_%','anxiety_risk_%']].head())\n","\n","# -------------------------------\n","# 📊 GRAPH 1: AVERAGE\n","# -------------------------------\n","avg_risks = [\n","    np.nan_to_num(df['eye_risk_%'].mean()),\n","    np.nan_to_num(df['depression_risk_%'].mean()),\n","    np.nan_to_num(df['sleep_risk_%'].mean()),\n","    np.nan_to_num(df['anxiety_risk_%'].mean())\n","]\n","\n","labels = ['Eye', 'Depression', 'Sleep', 'Anxiety']\n","\n","plt.figure(figsize=(8,5))\n","plt.bar(labels, avg_risks, color=['blue','red','green','orange'])\n","plt.title('Average Health Risk Distribution')\n","plt.ylabel('Risk (%)')\n","plt.show()\n","\n","# -------------------------------\n","# 📊 GRAPH 2: RANDOM STUDENT\n","# -------------------------------\n","if len(df) > 0:\n","    student = df.sample(1).iloc[0]\n","\n","    values = [\n","        student['eye_risk_%'],\n","        student['depression_risk_%'],\n","        student['sleep_risk_%'],\n","        student['anxiety_risk_%']\n","    ]\n","\n","    plt.figure(figsize=(8,5))\n","    plt.bar(labels, values, color=['purple','red','green','orange'])\n","    plt.title('Individual Health Risk Profile')\n","    plt.ylabel('Risk (%)')\n","    plt.show()\n","\n","# -------------------------------\n","# 📊 GRAPH 3: PIE CHART\n","# -------------------------------\n","plt.figure(figsize=(6,6))\n","plt.pie(avg_risks, labels=labels, autopct='%1.1f%%')\n","plt.title('Health Risk Contribution')\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"Iuy5oFyikzt4","executionInfo":{"status":"ok","timestamp":1776147878078,"user_tz":-330,"elapsed":1503,"user":{"displayName":"Yogita .Y.V","userId":"06419607842319088803"}},"outputId":"c7e28102-65a3-46f2-abe3-608f4270eb65"},"execution_count":17,"outputs":[{"output_type":"stream","name":"stdout","text":["   eye_risk_%  depression_risk_%  sleep_risk_%  anxiety_risk_%\n","0        20.0          49.999940          50.0       17.999964\n","1        20.0          71.999896          50.0       37.999924\n","2        20.0          63.999912          50.0       29.999940\n","3        20.0          83.999872          50.0       41.999916\n","4        20.0          69.999900          50.0       35.999928\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["print(\"Rows:\", data.shape[0])\n","print(\"Columns:\", data.shape[1])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":158},"id":"3QLw4WzEQVYi","executionInfo":{"status":"error","timestamp":1776147963210,"user_tz":-330,"elapsed":53,"user":{"displayName":"Yo